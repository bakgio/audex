# Rust build artifacts
/target/

# Cargo lock (library crate — downstream resolves its own dependencies)
Cargo.lock

# Cargo backup files
*.rs.bk

# Fuzz artifacts (corpora, crashes, coverage are local)
/fuzz/target/
/fuzz/corpus/
/fuzz/artifacts/
/fuzz/coverage/
fuzz-*.log

# WASM build output (generated by wasm-pack)
/wasm/pkg/
/wasm/pkg-node/
